# ─── Supabase ───────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude AI) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Stripe ─────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ─── Awin ────────────────────────────────────────────────────
# Get from: https://ui.awin.com → Account → API credentials
AWIN_API_KEY=your-awin-api-key
AWIN_PUBLISHER_ID=your-publisher-id

# ─── Email (Brevo) ───────────────────────────────────────────
# Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=your-brevo-api-key

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
